APP_ENV=development
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/messaging
REDIS_URL=redis://redis:6379/0

MESSAGE_PROVIDER=local_mock
SMS_PROVIDER=local_mock
SMS_API_KEY=
SMS_API_SECRET=
SMS_SENDER_ID=
SMS_WEBHOOK_SECRET=

EMAIL_PROVIDER=mailpit
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@example.com

PUBLIC_BASE_URL=http://localhost:8001
DEFAULT_TIMEZONE=America/New_York
QUIET_HOURS_START=21
QUIET_HOURS_END=8
PROMO_MAX_PER_DAY=1
PROMO_MAX_PER_WEEK=3
TXN_MAX_PER_DAY=5
TXN_MAX_PER_WEEK=20
OTP_COOLDOWN_SECONDS=45
OTP_MAX_PER_HOUR=3
GLOBAL_HOURLY_CAP=10000
GLOBAL_DAILY_CAP=100000
DUPLICATE_WINDOW_MINUTES=60

ADMIN_API_KEYS=admin_key_123:admin,review_key_123:reviewer,ops_key_123:operator,view_key_123:viewer
CAMPAIGN_BATCH_SIZE=100
CAMPAIGN_BATCH_INTERVAL_SECONDS=60
RETRY_MAX_ATTEMPTS=3
RETRY_BACKOFF_SECONDS=120
