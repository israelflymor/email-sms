APP_ENV=development
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/messaging
REDIS_URL=redis://redis:6379/0

# JWT Configuration (REQUIRED FOR PRODUCTION)
JWT_SECRET_KEY=your-secret-key-min-32-chars-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=15
JWT_REFRESH_EXPIRATION_DAYS=7

MESSAGE_PROVIDER=local_mock
SMS_PROVIDER=local_mock
SMS_API_KEY=
SMS_API_SECRET=
SMS_SENDER_ID=
SMS_WEBHOOK_SECRET=

EMAIL_PROVIDER=mailpit
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@example.com

PUBLIC_BASE_URL=http://localhost:8001
DEFAULT_TIMEZONE=America/New_York
QUIET_HOURS_START=21
QUIET_HOURS_END=8
PROMO_MAX_PER_DAY=1
PROMO_MAX_PER_WEEK=3
TXN_MAX_PER_DAY=5
TXN_MAX_PER_WEEK=20
OTP_COOLDOWN_SECONDS=45
OTP_MAX_PER_HOUR=3
GLOBAL_HOURLY_CAP=10000
GLOBAL_DAILY_CAP=100000
DUPLICATE_WINDOW_MINUTES=60

# DEPRECATED: Use JWT authentication instead
# ADMIN_API_KEYS is no longer used

CAMPAIGN_BATCH_SIZE=100
CAMPAIGN_BATCH_INTERVAL_SECONDS=60
RETRY_MAX_ATTEMPTS=3
RETRY_BACKOFF_SECONDS=120

# Security Settings
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8001
REQUIRE_HTTPS=false
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_DIGITS=true
PASSWORD_REQUIRE_SPECIAL_CHARS=true
